{
  "name": "provodnik-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && eslint",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff --schema public",
    "db:push": "supabase db push",
    "db:migrate": "supabase migration new",
    "types": "supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "types:remote": "supabase gen types typescript --linked > src/lib/supabase/database.types.ts",
    "playwright": "playwright test",
    "playwright:e2e": "playwright test tests/e2e/tripster-v1/",
    "postinstall": "sh scripts/install-hooks.sh"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/geist-mono": "^5.2.7",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.48.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "resend": "^6.10.0",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.1",
    "supabase": "^2.78.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "supabase",
    "unrs-resolver"
  ]
}
