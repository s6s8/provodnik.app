NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Optional legacy aliases still supported by the app:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# Needed for `supabase link` and `supabase db push` against the hosted project:
# SUPABASE_DB_PASSWORD=

# Local/demo QA: disable Sentry init, source-map uploads, and browser tunnel traffic.
# Set both to 1 in .env.local; leave unset/0 in hosted environments where Sentry should run.
# SENTRY_DISABLED=1
# NEXT_PUBLIC_SENTRY_DISABLED=1

# Feature flags — canonical registry: src/lib/flags.ts (8 flags).
# Sub-flags default to 0 (off). FEATURE_PUBLIC_CATALOG defaults to 1 (on).
# Nav links for gated routes are hidden via NAV_FLAG_BY_HREF in src/lib/navigation.ts.
# /help is always public; only its «Оплата» category follows FEATURE_TR_PAYMENT.
#
# FEATURE_TR_TOURS=1           # tour-shaped listing detail surfaces
# FEATURE_TR_NOTIFICATIONS=1   # /account/notifications + bell
# FEATURE_TR_PAYMENT=1         # payment help category and related surfaces
# FEATURE_TR_FAVORITES=1       # /favorites cabinet (unavailable screen when off)
# FEATURE_TR_PARTNER=1         # partner account surfaces
# FEATURE_TR_REFERRALS=1       # /referrals cabinet page + menu link
# FEATURE_TR_DISPUTES=1        # dispute flows on booking detail
# FEATURE_PUBLIC_CATALOG=0     # hide /listings + /destinations nav and routes
#                              # (defaults on when unset — keep consistent across envs)
