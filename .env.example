NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Optional legacy aliases still supported by the app:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# Needed for `supabase link` and `supabase db push` against the hosted project:
# SUPABASE_DB_PASSWORD=

# Local/demo QA: disable Sentry init, source-map uploads, and browser tunnel traffic.
# Set both to 1 in .env.local; leave unset/0 in hosted environments where Sentry should run.
# SENTRY_DISABLED=1
# NEXT_PUBLIC_SENTRY_DISABLED=1

# Feature flags (default 0 = off). Pages behind an off flag render notFound();
# their nav/footer links are hidden automatically (see src/lib/navigation.ts
# NAV_FLAG_BY_HREF). Enable in .env.local to demo the gated surfaces:
# FEATURE_TR_HELP=1            # /help (Центр помощи) + footer "Помощь" link
# FEATURE_TR_FAVORITES=1       # /favorites (Избранное) cabinet page + menu link
# FEATURE_TR_REFERRALS=1       # /referrals (Приглашения) cabinet page + menu link
# FEATURE_TR_NOTIFICATIONS=1   # /account/notifications settings + bell
# FEATURE_TR_PAYMENT=1         # payment help category and related surfaces
# FEATURE_PUBLIC_CATALOG=1     # /listings «Готовые экскурсии» nav entry + route,
#                              #   /destinations route. Off => nav entry hidden and
#                              #   /listings redirects to /guides.
#                              #   Set on ALL environments or the catalog silently
#                              #   differs between preview and prod (env drift).
