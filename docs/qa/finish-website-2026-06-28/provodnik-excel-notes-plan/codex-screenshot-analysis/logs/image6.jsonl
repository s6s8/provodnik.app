{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/features/profile/actions/updateLegalInformation.test.ts | sed -n '1,120p'\"","aggregated_output":"     1\timport { beforeEach, describe, expect, it, vi } from \"vitest\";\n     2\t\n     3\tconst getUserMock = vi.fn();\n     4\tconst fromMock = vi.fn();\n     5\tconst updateGuideProfileMock = vi.fn();\n     6\t\n     7\tvi.mock(\"@/lib/supabase/server\", () => ({\n     8\t  createSupabaseServerClient: vi.fn(async () => ({\n     9\t    auth: { getUser: getUserMock },\n    10\t    from: fromMock,\n    11\t  })),\n    12\t}));\n    13\t\n    14\timport { updateLegalInformation } from \"./updateLegalInformation\";\n    15\t\n    16\tfunction guideProfileQuery(verificationStatus: \"approved\" | \"draft\") {\n    17\t  return {\n    18\t    select: vi.fn(() => ({\n    19\t      eq: vi.fn(() => ({\n    20\t        maybeSingle: vi.fn().mockResolvedValue({\n    21\t          data: { verification_status: verificationStatus },\n    22\t        }),\n    23\t      })),\n    24\t    })),\n    25\t    update: updateGuideProfileMock,\n    26\t  };\n    27\t}\n    28\t\n    29\tconst legalInformation = {\n    30\t  legalStatus: \"self_employed\",\n    31\t  inn: \"123456789012\",\n    32\t  documentCountry: \"RU\",\n    33\t  isTourOperator: false,\n    34\t  tourOperatorRegistryNumber: null,\n    35\t};\n    36\t\n    37\tdescribe(\"updateLegalInformation\", () => {\n    38\t  beforeEach(() => {\n    39\t    vi.clearAllMocks();\n    40\t    getUserMock.mockResolvedValue({\n    41\t      data: { user: { id: \"g-guide-1\" } },\n    42\t    });\n    43\t  });\n    44\t\n    45\t  it(\"blocks legal information changes for an approved guide profile\", async () => {\n    46\t    fromMock.mockImplementation((table: string) => {\n    47\t      if (table === \"guide_profiles\") return guideProfileQuery(\"approved\");\n    48\t      throw new Error(`unexpected table: ${table}`);\n    49\t    });\n    50\t\n    51\t    await expect(updateLegalInformation(legalInformation)).rejects.toThrow(\"Профиль одобрен\");\n    52\t\n    53\t    expect(updateGuideProfileMock).not.toHaveBeenCalled();\n    54\t  });\n    55\t\n    56\t  it(\"updates legal information while the guide profile is not approved\", async () => {\n    57\t    const eqAfterUpdate = vi.fn().mockResolvedValue({ error: null });\n    58\t    updateGuideProfileMock.mockReturnValue({ eq: eqAfterUpdate });\n    59\t    fromMock.mockImplementation((table: string) => {\n    60\t      if (table === \"guide_profiles\") return guideProfileQuery(\"draft\");\n    61\t      throw new Error(`unexpected table: ${table}`);\n    62\t    });\n    63\t\n    64\t    await expect(updateLegalInformation(legalInformation)).resolves.toEqual({ success: true });\n    65\t\n    66\t    expect(updateGuideProfileMock).toHaveBeenCalledWith({\n    67\t      legal_status: \"self_employed\",\n    68\t      inn: \"123456789012\",\n    69\t      document_country: \"RU\",\n    70\t      is_tour_operator: false,\n    71\t      tour_operator_registry_number: null,\n    72\t    });\n    73\t    expect(eqAfterUpdate).toHaveBeenCalledWith(\"user_id\", \"g-guide-1\");\n    74\t  });\n    75\t});\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/features/profile/actions/updateLegalInformation.ts | sed -n '1,120p'\"","aggregated_output":"     1\t\"use server\";\n     2\t\n     3\timport { z } from \"zod\";\n     4\timport { isGuideProfileConfirmed } from \"@/lib/profile/guide-verification\";\n     5\timport { createSupabaseServerClient } from \"@/lib/supabase/server\";\n     6\t\n     7\tconst legalInformationSchema = z.object({\n     8\t  legalStatus: z.enum([\"self_employed\", \"individual\", \"company\", \"null\"]).nullable().optional(),\n     9\t  inn: z.string().nullable().optional(),\n    10\t  documentCountry: z.string().nullable().optional(),\n    11\t  isTourOperator: z.boolean().optional(),\n    12\t  tourOperatorRegistryNumber: z.string().nullable().optional(),\n    13\t});\n    14\t\n    15\texport async function updateLegalInformation(data: {\n    16\t  legalStatus: string | null;\n    17\t  inn: string | null;\n    18\t  documentCountry: string | null;\n    19\t  isTourOperator: boolean;\n    20\t  tourOperatorRegistryNumber: string | null;\n    21\t}) {\n    22\t  const parsed = legalInformationSchema.safeParse(data);\n    23\t  if (!parsed.success) {\n    24\t    throw new Error(\"Некорректные данные юридической информации.\");\n    25\t  }\n    26\t\n    27\t  const supabase = await createSupabaseServerClient();\n    28\t  const {\n    29\t    data: { user },\n    30\t  } = await supabase.auth.getUser();\n    31\t  if (!user) throw new Error(\"Unauthorized\");\n    32\t\n    33\t  const { data: statusRow } = await supabase\n    34\t    .from(\"guide_profiles\")\n    35\t    .select(\"verification_status\")\n    36\t    .eq(\"user_id\", user.id)\n    37\t    .maybeSingle();\n    38\t  if (isGuideProfileConfirmed(statusRow?.verification_status)) {\n    39\t    throw new Error(\"Профиль одобрен — для изменения данных обратитесь к администраторам\");\n    40\t  }\n    41\t\n    42\t  const { error } = await supabase\n    43\t    .from(\"guide_profiles\")\n    44\t    .update({\n    45\t      legal_status: (parsed.data.legalStatus === \"null\" ? null : parsed.data.legalStatus) as \"self_employed\" | \"individual\" | \"company\" | null,\n    46\t      inn: parsed.data.inn,\n    47\t      document_country: parsed.data.documentCountry,\n    48\t      is_tour_operator: parsed.data.isTourOperator,\n    49\t      tour_operator_registry_number: parsed.data.tourOperatorRegistryNumber,\n    50\t    })\n    51\t    .eq(\"user_id\", user.id);\n    52\t\n    53\t  if (error) throw new Error(error.message);\n    54\t  return { success: true };\n    55\t}\n","exit_code":0,"status":"completed"}}
