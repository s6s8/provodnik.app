ndary>\n\n      <GuideProfileSectionBoundary id=\"license\" title=\"Документ о квалификации\">\n        {() => (\n          <Card className=\"border-border/70 bg-card/90\">\n            <CardHeader>\n              <CardTitle className=\"text-xl\">Документ о квалификации</CardTitle>\n              <CardDescription>\n","exit_code":0,"status":"completed"}}
