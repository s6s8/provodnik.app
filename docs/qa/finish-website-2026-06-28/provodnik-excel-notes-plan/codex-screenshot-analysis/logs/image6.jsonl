{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/bin/zsh -lc \"nl -ba 'src/app/(protected)/guide/profile/page.tsx' | sed -n '100,350p'\"","aggregated_output":"   100\t      .from(\"profiles\")\n   101\t      .select(\"avatar_url, full_name\")\n   102\t      .eq(\"id\", guideId)\n   103\t      .maybeSingle();\n   104\t    if (profileRow) {\n   105\t      avatarUrl = (profileRow as { avatar_url?: string | null }).avatar_url ?? null;\n   106\t      const fullName = (profileRow as { full_name?: string | null }).full_name;\n   107\t      displayName = resolveDisplayName(\"guide\", { full_name: fullName ?? auth.email ?? null });\n   108\t    }\n   109\t  } catch {\n   110\t    // fall back to defaults\n   111\t  }\n   112\t\n   113\t\n   114\t  let profile: Partial<GuideProfileRow> | null = null;\n   115\t  let verificationStatus: GuideVerificationStatusDb = \"draft\";\n   116\t  let verificationNotes: string | null = null;\n   117\t  let listings: GuideListingOption[] = [];\n   118\t  let licenses: GuideLicenseView[] = [];\n   119\t  let documents: UploadedGuideDocument[] = [];\n   120\t  let legalInitialData = {\n   121\t    legalStatus: null as string | null,\n   122\t    inn: null as string | null,\n   123\t    documentCountry: null as string | null,\n   124\t    isTourOperator: false,\n   125\t    tourOperatorRegistryNumber: null as string | null,\n   126\t  };\n   127\t\n   128\t  try {\n   129\t    const supabase = await createSupabaseServerClient();\n   130\t    const { data: verificationRow } = await supabase\n   131\t      .from(\"guide_profiles\")\n   132\t      .select(\"verification_status\")\n   133\t      .eq(\"user_id\", guideId)\n   134\t      .maybeSingle();\n   135\t    if (verificationRow?.verification_status) {\n   136\t      verificationStatus = verificationRow.verification_status as GuideVerificationStatusDb;\n   137\t    }\n   138\t  } catch (err) {\n   139\t    console.error(\"[GuideProfilePage] verification status fetch failed:\", err);\n   140\t  }\n   141\t\n   142\t  const isVerifiedDataLocked = isGuideProfileConfirmed(verificationStatus);\n   143\t\n   144\t  try {\n   145\t    const supabase = await createSupabaseServerClient();\n   146\t    const [profileRes, licenseRes, listingRes, documentRes] = await Promise.all([\n   147\t      supabase\n   148\t        .from(\"guide_profiles\")\n   149\t        .select(\n   150\t          \"bio, base_city, languages, specializations, years_experience, regions, legal_status, inn, document_country, is_tour_operator, tour_operator_registry_number, verification_status, verification_notes\",\n   151\t        )\n   152\t        .eq(\"user_id\", guideId)\n   153\t        .maybeSingle(),\n   154\t      supabase\n   155\t        .from(\"guide_licenses\")\n   156\t        .select(\"id, license_type, license_number, issued_by, valid_until, scope_mode\")\n   157\t        .eq(\"guide_id\", guideId)\n   158\t        .order(\"created_at\", { ascending: false }),\n   159\t      supabase\n   160\t        .from(\"listings\")\n   161\t        .select(\"id, title\")\n   162\t        .eq(\"guide_id\", guideId)\n   163\t        .in(\"status\", SCOPABLE_LISTING_STATUSES)\n   164\t        .order(\"title\", { ascending: true }),\n   165\t      supabase\n   166\t        .from(\"guide_documents\")\n   167\t        .select(\"id, document_type, status, storage_assets!inner(id, object_path)\")\n   168\t        .eq(\"guide_id\", guideId)\n   169\t        .order(\"created_at\", { ascending: false }),\n   170\t    ]);\n   171\t\n   172\t    profile = profileRes.data;\n   173\t    if (profile?.verification_status) {\n   174\t      verificationStatus = profile.verification_status as GuideVerificationStatusDb;\n   175\t    }\n   176\t    verificationNotes = profile?.verification_notes ?? null;\n   177\t\n   178\t    listings =\n   179\t      listingRes.data?.map((l) => ({ id: l.id, title: l.title })) ?? [];\n   180\t\n   181\t    const licenseIds = (licenseRes.data ?? []).map((r) => r.id);\n   182\t    const titleById = new Map(listings.map((l) => [l.id, l.title] as const));\n   183\t\n   184\t    let links: { license_id: string; listing_id: string }[] = [];\n   185\t    if (licenseIds.length > 0) {\n   186\t      const { data: linkRows } = await supabase\n   187\t        .from(\"listing_licenses\")\n   188\t        .select(\"license_id, listing_id\")\n   189\t        .in(\"license_id\", licenseIds);\n   190\t      links = linkRows ?? [];\n   191\t    }\n   192\t\n   193\t    const titlesByLicense = new Map<string, string[]>();\n   194\t    for (const row of links) {\n   195\t      const title = titleById.get(row.listing_id);\n   196\t      if (!title) continue;\n   197\t      const arr = titlesByLicense.get(row.license_id) ?? [];\n   198\t      arr.push(title);\n   199\t      titlesByLicense.set(row.license_id, arr);\n   200\t    }\n   201\t\n   202\t    licenses =\n   203\t      (licenseRes.data ?? []).map((row) => ({\n   204\t        id: row.id,\n   205\t        licenseType: row.license_type,\n   206\t        licenseNumber: row.license_number,\n   207\t        issuedBy: row.issued_by,\n   208\t        validUntil: row.valid_until,\n   209\t        scopeMode: row.scope_mode === \"all\" ? \"all\" : \"selected\",\n   210\t        listingTitles: titlesByLicense.get(row.id) ?? [],\n   211\t      }));\n   212\t\n   213\t    documents = (\n   214\t      (documentRes.data ?? []) as GuideVerificationDocumentRow[]\n   215\t    )\n   216\t      .map((row) => {\n   217\t        const asset = getStorageAsset(row.storage_assets);\n   218\t        if (!asset) return null;\n   219\t        return {\n   220\t          assetId: asset.id,\n   221\t          documentType: row.document_type,\n   222\t          objectPath: asset.object_path,\n   223\t          fileName: asset.object_path.split(\"/\").at(-1) ?? asset.object_path,\n   224\t          status: row.status,\n   225\t        };\n   226\t      })\n   227\t      .filter((item): item is UploadedGuideDocument => Boolean(item));\n   228\t\n   229\t    legalInitialData = {\n   230\t      legalStatus: profile?.legal_status ?? null,\n   231\t      inn: profile?.inn ?? null,\n   232\t      documentCountry: profile?.document_country ?? null,\n   233\t      isTourOperator: profile?.is_tour_operator ?? false,\n   234\t      tourOperatorRegistryNumber: profile?.tour_operator_registry_number ?? null,\n   235\t    };\n   236\t  } catch (err) {\n   237\t    console.error(\"[GuideProfilePage] data fetch failed:\", err);\n   238\t  }\n   239\t\n   240\t  const avatarDone = avatarUrl != null;\n   241\t  const aboutDone = (profile?.bio ?? \"\").trim().length > 0;\n   242\t  const legalDone = Boolean(\n   243\t    legalInitialData.legalStatus &&\n   244\t      legalInitialData.inn &&\n   245\t      legalInitialData.documentCountry,\n   246\t  );\n   247\t  const licenseDone = licenses.length > 0;\n   248\t  const verificationDone = verificationStatus !== \"draft\";\n   249\t  const isAnketaComplete = aboutDone && legalDone && licenseDone;\n   250\t\n   251\t  const lockedStatus: ChecklistStep[\"status\"] = isVerifiedDataLocked\n   252\t    ? \"locked\"\n   253\t    : \"todo\";\n   254\t\n   255\t  const steps: ChecklistStep[] = [\n   256\t    {\n   257\t      id: \"avatar\",\n   258\t      label: \"Аватар\",\n   259\t      anchor: \"avatar\",\n   260\t      status: avatarDone ? \"done\" : \"todo\",\n   261\t    },\n   262\t    {\n   263\t      id: \"about\",\n   264\t      label: \"О себе\",\n   265\t      anchor: \"about\",\n   266\t      status: aboutDone ? \"done\" : lockedStatus,\n   267\t    },\n   268\t    {\n   269\t      id: \"legal\",\n   270\t      label: \"Юр. данные\",\n   271\t      anchor: \"legal\",\n   272\t      status: legalDone ? \"done\" : lockedStatus,\n   273\t    },\n   274\t    {\n   275\t      id: \"license\",\n   276\t      label: \"Лицензия\",\n   277\t      anchor: \"license\",\n   278\t      status: licenseDone ? \"done\" : lockedStatus,\n   279\t    },\n   280\t    {\n   281\t      id: \"verification\",\n   282\t      label: \"Верификация\",\n   283\t      anchor: \"verification\",\n   284\t      status: verificationDone ? \"done\" : \"todo\",\n   285\t    },\n   286\t  ];\n   287\t  const firstIncompleteStep = steps.find((step) => step.status !== \"done\") ?? null;\n   288\t\n   289\t  return (\n   290\t    <div className=\"space-y-10\">\n   291\t      <header className=\"space-y-2\">\n   292\t        <h1 className=\"text-3xl font-semibold tracking-tight text-foreground\">Профиль гида</h1>\n   293\t        <p className=\"text-sm text-muted-foreground\">\n   294\t          Заполните разделы ниже — мы подскажем следующий шаг.\n   295\t        </p>\n   296\t      </header>\n   297\t\n   298\t      <GuideProfileChecklist\n   299\t        steps={steps}\n   300\t        firstIncompleteStep={firstIncompleteStep}\n   301\t        verificationStatus={verificationStatus}\n   302\t      />\n   303\t\n   304\t      <GuideProfileSectionBoundary id=\"avatar\" title=\"Фото\">\n   305\t        {() => <AvatarUploadBlock avatarUrl={avatarUrl} displayName={displayName} />}\n   306\t      </GuideProfileSectionBoundary>\n   307\t\n   308\t      <GuideProfileSectionBoundary id=\"about\" title=\"О себе\">\n   309\t        {() => (\n   310\t          <Card className=\"border-border/70 bg-card/90\">\n   311\t            <CardHeader>\n   312\t              <CardTitle className=\"text-xl\">О себе</CardTitle>\n   313\t            </CardHeader>\n   314\t            <CardContent>\n   315\t              <GuideAboutForm\n   316\t                initialBio={profile?.bio ?? \"\"}\n   317\t                initialBaseCity={profile?.base_city ?? \"\"}\n   318\t                initialLanguages={profile?.languages ?? []}\n   319\t                initialSpecializations={profile?.specializations ?? []}\n   320\t                initialYearsExperience={profile?.years_experience ?? null}\n   321\t                initialRegions={profile?.regions ?? []}\n   322\t                isLocked={isVerifiedDataLocked}\n   323\t              />\n   324\t            </CardContent>\n   325\t          </Card>\n   326\t        )}\n   327\t      </GuideProfileSectionBoundary>\n   328\t\n   329\t      <GuideProfileSectionBoundary id=\"legal\" title=\"Юридические данные\">\n   330\t        {() => (\n   331\t          <Card className=\"border-border/70 bg-card/90\">\n   332\t            <CardHeader>\n   333\t              <CardTitle className=\"text-xl\">Юридические данные</CardTitle>\n   334\t              <p className=\"text-sm text-muted-foreground\">\n   335\t                ИНН, статус, страна документа.\n   336\t              </p>\n   337\t            </CardHeader>\n   338\t            <CardContent>\n   339\t              <LegalInformationForm initialData={legalInitialData} isLocked={isVerifiedDataLocked} />\n   340\t            </CardContent>\n   341\t          </Card>\n   342\t        )}\n   343\t      </GuideProfileSectionBoundary>\n   344\t\n   345\t      <GuideProfileSectionBoundary id=\"license\" title=\"Документ о квалификации\">\n   346\t        {() => (\n   347\t          <Card className=\"border-border/70 bg-card/90\">\n   348\t            <CardHeader>\n   349\t              <CardTitle className=\"text-xl\">Документ о квалификации</CardTitle>\n   350\t              <CardDescription>\n","exit_code":0,"status":"completed"}}
