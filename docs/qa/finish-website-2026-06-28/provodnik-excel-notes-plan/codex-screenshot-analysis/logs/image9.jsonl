e({ data: [], error: null }),\n   736\t  ]);\n   737\t\n   738\t  if (casesResult.error) throw casesResult.error;\n   739\t\n   740\t  const latestCaseByGuide = new Map<Uuid, ModerationCaseRow>();\n   741\t  for (const moderationCase of (casesResult.data ?? []) as ModerationCaseRow[]) {\n   742\t    if (moderationCase.guide_id && !latestCaseByGuide.has(moderationCase.guide_id)) {\n   743\t      latestCaseByGuide.set(moderationCase.guide_id, moderationCase);\n   744\t    }\n   745\t  }\n   746\t\n   747\t  const latestActions = await getLatestActionMap(\n   748\t    adminClient,\n   749\t    [...latestCaseByGuide.values()].map((item) => item.id),\n   750\t  );\n   751\t\n   752\t  return guideProfiles\n   753\t    .map((profile) => {\n   754\t      const latestCase = latestCaseByGuide.get(profile.user_id) ?? null;\n   755\t      return {\n   756\t        profile,\n   757\t        account: accounts.get(profile.user_id) ?? null,\n   758\t        latest_case: latestCase,\n   759\t        latest_action: latestCase ? latestActions.get(latestCase.id) ?? null : null,\n   760\t      };\n   761\t    })\n   762\t    .sort((left, right) => {\n   763\t      const leftPending = left.profile.verification_status === \"submitted\" ? 0 : 1;\n   764\t      const rightPending = right.profile.verification_status === \"submitted\" ? 0 : 1;\n   765\t      if (leftPending !== rightPending) return leftPending - rightPending;\n   766\t      return right.profile.updated_at.localeCompare(left.profile.updated_at);\n   767\t    });\n   768\t}\n   769\t\n   770\texport async function getGuideReviewDetail(guideId: string): Promise<GuideReviewDetail | null> {\n","exit_code":0,"status":"completed"}}
