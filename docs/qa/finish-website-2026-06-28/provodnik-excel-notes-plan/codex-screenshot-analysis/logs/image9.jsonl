ams?: Promise<Record<string, string | string[] | undefined>>;\r\n   109\t}) {\r\n   110\t  const resolvedSearchParams = (await searchParams) ?? {};\r\n   111\t  const view = resolveQueueView(resolvedSearchParams.view);\r\n   112\t  const guides = await getGuideReviewQueue({ view });\r\n   113\t  const emptyState =\r\n   114\t    view === \"drafts\"\r\n   115\t      ? \"Нет черновиков анкет гидов.\"\r\n   116\t      : \"Нет анкет в очереди верификации.\";\r\n   117\t  const filterBaseClass =\r\n   118\t    \"rounded-full px-4 py-2 text-sm font-medium transition-colors\";\r\n   119\t  const filterInactiveClass =\r\n   120\t    \"border border-border/70 text-muted-foreground hover:bg-surface-low hover:text-foreground\";\r\n   121\t  const filterActiveClass = \"bg-primary text-primary-foreground shadow-sm\";\r\n   122\t\r\n   123\t  return (\r\n   124\t    <div className=\"space-y-8\">\r\n   125\t      <div className=\"space-y-2\">\r\n   126\t        <h1 className=\"text-3xl font-semibold tracking-tight text-foreground\">\r\n   127\t          Проверка гидов\r\n   128\t        </h1>\r\n   129\t        <p className=\"max-w-3xl text-sm text-muted-foreground\">\r\n   130\t          В основной очереди только анкеты со статусом «На проверке». Черновики\r\n   131\t          и уже решённые заявки скрыты; для диагностики откройте «Черновики».\r\n   132\t        </p>\r\n   133\t      </div>\r\n   134\t\r\n   135\t      <div className=\"flex flex-wrap gap-2\" aria-label=\"Фильтр очереди гидов\">\r\n   136\t        <Link\r\n   137\t          href=\"/admin/guides\"\r\n   138\t          aria-current={view === \"all\" ? \"page\" : undefined}\r\n   139\t          className={`${filterBaseClass} ${\r\n   140\t            view === \"all\" ? filterActiveClass : filterInactiveClass\r\n   141\t          }`}\r\n   142\t        >\r\n   143\t          На проверке\r\n   144\t        </Link>\r\n   145\t        <Link\r\n   146\t          href=\"/admin/guides?view=drafts\"\r\n   147\t          aria