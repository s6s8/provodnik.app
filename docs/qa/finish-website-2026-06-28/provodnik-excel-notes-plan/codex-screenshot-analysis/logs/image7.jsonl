{"type":"item.completed","item":{"id":"item_26","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/data/themes.ts | sed -n '1,90p'\"","aggregated_output":"     1\timport type { LucideIcon } from \"lucide-react\";\n     2\timport {\n     3\t  Church,\n     4\t  Landmark,\n     5\t  Leaf,\n     6\t  Moon,\n     7\t  Mountain,\n     8\t  Palette,\n     9\t  Sparkles,\n    10\t  Utensils,\n    11\t  Waves,\n    12\t} from \"lucide-react\";\n    13\t\n    14\texport type ThemeSlug =\n    15\t  | \"history_culture\"\n    16\t  | \"nature\"\n    17\t  | \"food\"\n    18\t  | \"art\"\n    19\t  | \"unusual\"\n    20\t  | \"night\"\n    21\t  | \"active\"\n    22\t  | \"water\"\n    23\t  | \"religion\";\n    24\t\n    25\texport type Theme = {\n    26\t  slug: ThemeSlug;\n    27\t  label: string;\n    28\t  Icon: LucideIcon;\n    29\t};\n    30\t\n    31\texport const THEMES = [\n    32\t  { slug: \"history_culture\", label: \"История и культура\", Icon: Landmark },\n    33\t  { slug: \"nature\", label: \"Природа\", Icon: Leaf },\n    34\t  { slug: \"food\", label: \"Гастрономия\", Icon: Utensils },\n    35\t  { slug: \"art\", label: \"Искусство\", Icon: Palette },\n    36\t  { slug: \"unusual\", label: \"Необычные маршруты\", Icon: Sparkles },\n    37\t  { slug: \"night\", label: \"Ночные прогулки\", Icon: Moon },\n    38\t  { slug: \"active\", label: \"Активный отдых\", Icon: Mountain },\n    39\t  { slug: \"water\", label: \"Водные прогулки\", Icon: Waves },\n    40\t  { slug: \"religion\", label: \"Религия и духовность\", Icon: Church },\n    41\t] as const satisfies readonly Theme[];\n    42\t\n    43\texport function getTheme(slug: string): Theme | undefined {\n    44\t  return THEMES.find((t) => t.slug === slug);\n    45\t}\n","exit_code":0,"status":"completed"}}
