beforeEach(() => {\n    48\t    vi.clearAllMocks();\n    49\t    mockGetUser.mockResolvedValue({\n    50\t      data: { user: { id: \"g-guide-1\" } },\n    51\t      error: null,\n    52\t    });\n    53\t    mockSelect.mockReturnValue({ eq: mockEq });\n    54\t    mockEq.mockReturnValue({ maybeSingle: mockMaybeSingle });\n    55\t    mockMaybeSingle.mockResolvedValueOnce({\n    56\t      data: { verification_status: \"draft\" },\n    57\t    });\n    58\t    mockUpdate.mockReturnValue({\n    59\t      eq: vi.fn(() => ({\n    60\t        select: vi.fn(() => ({\n    61\t          maybeSingle: vi.fn().mockResolvedValue({ data: { user_id: \"g-guide-1\" }, error: null }),\n    62\t        })),\n    63\t      })),\n    64\t    });\n    65\t  });\n    66\t\n    67\t  it(\"persists regions that contain spaces\", async () => {\n    68\t    const result = await saveGuideAboutAction(makeFormData());\n    69\t\n    70\t    expect(result).toEqual({\n    71\t      ok: true,\n    72\t      regions: [\"Санкт Петербург\", \"Карелия\"],\n    73\t    });\n    74\t    expect(mockUpdate).toHaveBeenCalledWith(\n    75\t      expect.objectContaining({\n    76\t        regions: [\"Санкт Петербург\", \"Карелия\"],\n    77\t      }),\n    78\t    );\n    79\t    expect(mockInsert).not.toHaveBeenCalled();\n    80\t    expect(revalidatePath).toHaveBeenCalledWith(\"/guide/profile\");\n    81\t  });\n    82\t\n    83\t  it(\"inserts guide_profiles when the row is missing\", async () => {\n    84\t    mockUpdate.mockReturnValue({\n    85\t      eq: vi.fn(() => ({\n    86\t        select: vi.fn(() => ({\n    87\t          maybeSingle: vi.fn().mockResolvedValue({ data: null, error: null }),\n    88\t        })),\n    89\t      })),\n    90\t    });\n    91\t    mockInsert.mockReturnValue({\n    92\t      select: vi.fn(() => ({\n    93\t        maybeSingle: vi.fn().mockResolvedValue({ data: { user_id: \"g-guide-1\" }, error: null }),\n    94\t      })),\n    95\t    });\n    96\t\n    97\t    const result = await saveGuideAboutAction(makeFormData({ regions: [\"Республика Карелия\"] }));\n    98\t\n    99\t    expect(result).toEqual({ ok: true, regions: [\"Республика Карелия\"] });\n   100\t    expect(mockInsert).toHaveBeenCalledWith(\n   101\t      expect.objectContaining({\n   102\t        user_id: \"g-guide-1\",\n   103\t        regions: [\"Республика Карелия\"],\n   104\t      }),\n   105\t    );\n   106\t    expect(revalidatePath).toHaveBeenCalledWith(\"/guide/profile\");\n   107\t  });\n   108\t\n   109\t  it(\"updates only bio for an approved guide profile\", async () => {\n   110\t    mockMaybeSingle.mockReset();\n   111\t    mockMaybeSingle.mockResolvedValueOnce({\n   112\t      data: {\n   113\t        verification_status: \"approved\",\n   114\t        regions: [\"Карелия\"],\n   115\t      },\n   116\t    });\n   117\t    const eqAfterUpdate = vi.fn().mockResolvedValue({ error: null });\n   118\t    mockUpdate.mockReturnValue({ eq: eqAfterUpdate });\n   119\t\n   120\t    const formData = makeFormData();\n   121\t    formData.set(\"bio\", \"Новый публичный текст\");\n   122\t    formData.set(\"base_city\", \"Москва\");\n   123\t\n   124\t    const result = await saveGuideAboutAction(formData);\n   125\t\n   126\t    expect(result).toEqual({ ok: true, regions: [\"Карелия\"] });\n   127\t    expect(mockUpdate).toHaveBeenCalledWith({ bio: \"Новый публичный текст\" });\n   128\t    expect(eqAfterUpdate).toHaveBeenCalledWith(\"user_id\", \"g-guide-1\");\n   129\t    expect(mockInsert).not.toHaveBeenCalled();\n   130\t    expect(revalidatePath).toHaveBeenCalledWith(\"/guide/profile\");\n   131\t  });\n   132\t});\n","exit_code":0,"status":"completed"}}
