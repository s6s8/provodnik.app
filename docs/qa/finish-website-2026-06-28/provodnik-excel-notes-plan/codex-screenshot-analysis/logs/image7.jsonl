gle();\n    95\t\n    96\t    if (insertError || !insertedRow) {\n    97\t      return {\n    98\t        ok: false,\n    99\t        error: insertError?.message ?? \"Не удалось сохранить профиль гида.\",\n   100\t      };\n   101\t    }\n   102\t  }\n   103\t\n   104\t  revalidatePath(\"/guide/profile\");\n   105\t  return { ok: true, regions };\n   106\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_23","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/features/guide/components/profile/guide-about-form.tsx | sed -n '1,190p'\"","aggregated_output":"     1\t\"use client\";\n     2\t\n     3\timport * as React from \"react\";\n     4\timport { useRouter } from \"next/navigation\";\n     5\t\n     6\timport { Button } from \"@/components/ui/button\";\n     7\timport { LANGUAGES } from \"@/data/languages\";\n     8\timport { InterestChipGroup } from \"@/features/shared/components/interest-chip-group\";\n     9\timport {\n    10\t  formatGuideRegionsInput,\n    11\t  parseGuideRegionsInput,\n    12\t} from \"@/lib/profile/guide-regions\";\n    13\timport { saveGuideAboutAction } from \"@/features/guide/profile-actions\";\n    14\t\n    15\tinterface GuideAboutFormProps {\n    16\t  initialBio: string;\n    17\t  initialBaseCity: string;\n    18\t  initialLanguages: string[];\n    19\t  initialSpecializations: string[];\n    20\t  initialYearsExperience: number | null;\n    21\t  initialRegions: string[];\n    22\t  isLocked?: boolean;\n    23\t}\n    24\t\n    25\texport function GuideAboutForm({\n    26\t  initialBio,\n    27\t  initialBaseCity,\n    28\t  initialLanguages,\n    29\t  initialSpecializations,\n    30\t  initialYearsExperience,\n    31\t  initialRegions,\n    32\t  isLocked = false,\n    33\t}: GuideAboutFormProps) {\n    34\t  const router = useRouter();\n    35\t  const [status, setStatus] = React.useState<\"idle\" | \"saving\" | \"saved\" | \"error\">(\"idle\");\n    36\t  const [errorMsg, setErrorMsg] = React.useState(\"\");\n    37\t  const [baseCity, setBaseCity] = React.useState(initialBaseCity);\n    38\t  const [regionsRaw, setRegionsRaw] = React.useState(formatGuideRegionsInput(initialRegions));\n    39\t  const [specializations, setSpecializations] = React.useState<string[]>(initialSpecializations);\n    40\t  const parsedRegions = parseGuideRegionsInput(regionsRaw);\n    41\t\n    42\t  const handleSubmit = async (e: React.FormEvent<HTMLFormElement>) => {\n    43\t    e.preventDefault();\n    44\t    const formData = new FormData(e.currentTarget);\n    45\t\n    46\t    if (!isLocked) {\n    47\t      formData.set(\"base_city\", baseCity.trim());\n    48\t    }\n    49\t    setStatus(\"saving\");\n    50\t    const result = await saveGuideAboutAction(formData);\n    51\t    if (result.ok) {\n    52\t      setRegionsRaw(formatGuideRegionsInput(result.regions));\n    53\t      setStatus(\"saved\");\n    54\t      router.refresh();\n    55\t      setTimeout(() => setStatus(\"idle\"), 3000);\n    56\t    } else {\n    57\t      setErrorMsg(result.error);\n    58\t      setStatus(\"error\");\n    59\t    }\n    60\t  };\n    61\t\n    62\t  return (\n    63\t    <form onSubmit={(e) => void handleSubmit(e)} className=\"max-w-xl\">\n    64\t      {isLocked && (\n    65\t        <p className=\"mb-6 rounded-lg border border-warning/30 bg-warning/10 px-4 py-3 text-sm text-warning\">\n    66\t          Профиль одобрен. Проверенные данные недоступны для редактирования — для изменений напишите администраторам. Текст «О себе» можно обновлять.\n    67\t        </p>\n    68\t      )}\n    69\t      {/* Bio */}\n    70\t      <div className=\"space-y-2\">\n    71\t        <textarea\n    72\t          id=\"bio\"\n    73\t          name=\"bio\"\n    74\t          aria-label=\"О себе\"\n    75\t          defaultValue={initialBio}\n    76\t          rows={6}\n    77\t          placeholder=\"Расскажите о себе: опыт, специализация, что вас вдохновляет...\"\n    78\t          className=\"w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none resize-y\"\n    79\t        />\n    80\t        <p className=\"text-xs text-muted-foreground\">\n    81\t          Пишите честно и тепло — путешественники выбирают гида, а не резюме. Текст увидят все посетители вашей публичной страницы.\n    82\t        </p>\n    83\t      </div>\n    84\t\n    85\t      <fieldset disabled={isLocked} className=\"space-y-6 border-0 p-0 m-0\">\n    86\t      {/* Base city */}\n    87\t      <div className=\"space-y-2\">\n    88\t        <label htmlFor=\"base_city\" className=\"text-sm font-medium text-foreground\">\n    89\t          Базовый город\n    90\t        </label>\n    91\t        <input\n    92\t          id=\"base_city\"\n    93\t          name=\"base_city\"\n    94\t          type=\"text\"\n    95\t          value={baseCity}\n    96\t          onChange={(e) => setBaseCity(e.target.value)}\n    97\t          placeholder=\"Санкт-Петербург\"\n    98\t          className=\"w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none\"\n    99\t        />\n   100\t      </div>\n   101\t\n   102\t      {/* Regions */}\n   103\t      <div className=\"space-y-2\">\n   104\t        <label htmlFor=\"regions\" className=\"text-sm font-medium text-foreground\">\n   105\t          Регионы\n   106\t        </label>\n   107\t        <input\n   108\t          id=\"regions\"\n   109\t          type=\"text\"\n   110\t          value={regionsRaw}\n   111\t          onChange={(e) => setRegionsRaw(e.target.value)}\n   112\t          placeholder=\"Санкт-Петербург, Карелия\"\n   113\t          className=\"w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none\"\n   114\t        />\n   115\t        <p className=\"text-xs text-muted-foreground\">Через запятую — регионы, где вы проводите экскурсии.</p>\n   116\t        {parsedRegions.map((region, index) => (\n   117\t          <input key={`${index}-${region}`} type=\"hidden\" name=\"regions\" value={region} />\n   118\t        ))}\n   119\t      </div>\n   120\t\n   121\t      {/* Years of experience */}\n   122\t      <div className=\"space-y-2\">\n   123\t        <label htmlFor=\"years_experience\" className=\"text-sm font-medium text-foreground\">\n   124\t          Лет опыта в роли гида\n   125\t        </label>\n   126\t        <input\n   127\t          id=\"years_experience\"\n   128\t          name=\"years_experience\"\n   129\t          type=\"number\"\n   130\t          min={0}\n   131\t          max={60}\n   132\t          defaultValue={initialYearsExperience ?? \"\"}\n   133\t          placeholder=\"Например: 5\"\n   134\t          className=\"w-32 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none\"\n   135\t        />\n   136\t      </div>\n   137\t\n   138\t      {/* Languages */}\n   139\t      <fieldset className=\"space-y-2\">\n   140\t        <legend className=\"text-sm font-medium text-foreground\">Языки проведения экскурсий</legend>\n   141\t        <div className=\"grid grid-cols-2 gap-2 sm:grid-cols-3\">\n   142\t          {LANGUAGES.map((lang) => (\n   143\t            <label\n   144\t              key={lang}\n   145\t              className=\"flex min-h-11 items-center gap-3 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground cursor-pointer hover:bg-muted/50 has-[:checked]:border-primary has-[:checked]:bg-primary/5\"\n   146\t            >\n   147\t              <input\n   148\t                type=\"checkbox\"\n   149\t                name=\"languages\"\n   150\t                value={lang}\n   151\t                defaultChecked={initialLanguages.includes(lang)}\n   152\t                className=\"size-5 rounded border-border accent-primary\"\n   153\t              />\n   154\t              {lang}\n   155\t            </label>\n   156\t          ))}\n   157\t        </div>\n   158\t      </fieldset>\n   159\t\n   160\t      <fieldset className=\"space-y-2\">\n   161\t        <legend className=\"text-sm font-medium text-foreground\">Темы экскурсий</legend>\n   162\t        <p className=\"text-xs text-muted-foreground\">\n   163\t          Отметьте темы, по которым вы готовы вести экскурсии. Запросы по этим темам будут показаны в верху вашей ленты. Остальные запросы по-прежнему видны.\n   164\t        </p>\n   165\t        <InterestChipGroup\n   166\t          name=\"specializations\"\n   167\t          selected={specializations}\n   168\t          onChange={setSpecializations}\n   169\t          ariaLabel=\"Темы экскурсий\"\n   170\t        />\n   171\t      </fieldset>\n   172\t\n   173\t      </fieldset>\n   174\t      <div className=\"flex items-center gap-3\">\n   175\t        <Button type=\"submit\" disabled={status === \"saving\"}>\n   176\t          {status === \"saving\" ? \"Сохраняем…\" : \"Сохранить\"}\n   177\t        </Button>\n   178\t        {status === \"saved\" ? (\n   179\t          <p className=\"text-sm text-success\">Сохранено</p>\n   180\t        ) : null}\n   181\t        {status === \"error\" ? (\n   182\t          <p className=\"text-sm text-destructive\">{errorMsg}</p>\n   183\t        ) : null}\n   184\t      </div>\n   185\t    </form>\n   186\t  );\n   187\t}\n","exit_code":0,"status":"completed"}}
