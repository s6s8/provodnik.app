ull bg-white/10\">\n    84\t                  <Check className=\"size-3.5 text-white\" />\n    85\t                </span>\n    86\t                <span className=\"text-sm leading-6 text-white/85\">{point}</span>\n    87\t              </li>\n    88\t            ))}\n    89\t          </ul>\n    90\t        </aside>\n    91\t\n    92\t        <div className=\"flex items-center justify-center\">\n    93\t          <AuthEntryScreen\n    94\t            role={signupRole}\n    95\t            next={next}\n    96\t            errorCode={needsAdminReauth ? \"admin-access-denied\" : error}\n    97\t          />\n    98\t        </div>\n    99\t      </div>\n   100\t    </section>\n   101\t  );\n   102\t}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_12","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/features/auth/components/auth-entry-screen.tsx | sed -n '1,420p'\"","aggregated_output":"     1\t\"use client\";\n     2\t\n     3\timport { useEffect, useState } from \"react\";\n     4\t\n     5\timport Link from \"next/link\";\n     6\timport {\n     7\t  AlertCircle,\n     8\t  CheckCircle2,\n     9\t  Eye,\n    10\t  EyeOff,\n    11\t  LockKeyhole,\n    12\t  Mail,\n    13\t  Phone,\n    14\t  UserRound,\n    15\t} from \"lucide-react\";\n    16\t\n    17\timport { Button } from \"@/components/ui/button\";\n    18\timport { Input } from \"@/components/ui/input\";\n    19\timport { resolveCanonicalRole } from \"@/lib/auth/role-routing\";\n    20\timport {\n    21\t  isAdminWorkspacePath,\n    22\t  resolvePostAuthRedirectPath,\n    23\t} from \"@/lib/auth/safe-redirect\";\n    24\timport { hasSupabaseEnv } from \"@/lib/env\";\n    25\timport { createSupabaseBrowserClient } from \"@/lib/supabase/client\";\n    26\timport { signUpAction } from \"@/features/auth/actions/signUpAction\";\n    27\t\n    28\ttype AuthFormMode = \"sign-in\" | \"sign-up\";\n    29\t\n    30\tfunction getFriendlyAuthError(code: string): string {\n    31\t  switch (code) {\n    32\t    case \"already_registered\":\n    33\t      return \"Этот email уже зарегистрирован. Войдите в существующий аккаунт или используйте другой адрес.\";\n    34\t    case \"internal\":\n    35\t      return \"Что-то пошло не так. Попробуйте ещё раз.\";\n    36\t    case \"profile_failed\":\n    37\t    case \"role_failed\":\n    38\t      return \"Не удалось завершить регистрацию. Попробуйте ещё раз.\";\n    39\t    case \"signin_after_signup_failed\":\n    40\t      return \"Аккаунт создан. Войдите по своему email и паролю.\";\n    41\t    case \"forbidden_role\":\n    42\t      return \"Регистрация для этой роли недоступна.\";\n    43\t  }\n    44\t\n    45\t  const normalized = code.toLowerCase();\n    46\t\n    47\t  if (\n    48\t    normalized.includes(\"database error\") ||\n    49\t    normalized.includes(\"querying schema\") ||\n    50\t    normalized.includes(\"error granting user\")\n    51\t  ) {\n    52\t    return \"Не удалось завершить вход: ошибка выдачи сессии. Попробуйте ещё раз через минуту или напишите в поддержку.\";\n    53\t  }\n    54\t  if (normalized.includes(\"invalid login credentials\")) {\n    55\t    return \"Неверный email или пароль.\";\n    56\t  }\n    57\t  if (normalized.includes(\"user already registered\")) {\n    58\t    return \"Этот email уже зарегистрирован. Войдите в существующий аккаунт или используйте другой адрес.\";\n    59\t  }\n    60\t  if (normalized.includes(\"email not confirmed\")) {\n    61\t    return \"Подтвердите email по письму и попробуйте снова.\";\n    62\t  }\n    63\t  if (normalized.includes(\"password should be at least\") || normalized.includes(\"password must be at least\")) {\n    64\t    return \"Пароль слишком короткий. Используйте не менее 6 символов.\";\n    65\t  }\n    66\t\n    67\t  return \"Что-то пошло не так. Попробуйте ещё раз.\";\n    68\t}\n    69\t\n    70\ttype AuthEntryScreenProps = {\n    71\t  role?: \"traveler\" | \"guide\";\n    72\t  next?: string;\n    73\t  errorCode?: string;\n    74\t};\n    75\t\n    76\texport function AuthEntryScreen({\n    77\t  role = \"traveler\",\n    78\t  next,\n    79\t  errorCode,\n    80\t}: AuthEntryScreenProps) {\n    81\t  const [mode, setMode] = useState<AuthFormMode>(\n    82\t    role === \"guide\" ? \"sign-up\" : \"sign-in\",\n    83\t  );\n    84\t  const [email, setEmail] = useState(\"\");\n    85\t  const [password, setPassword] = useState(\"\");\n    86\t  const [fullName, setFullName] = useState(\"\");\n    87\t  const [phone, setPhone] = useState(\"\");\n    88\t  const [showPassword, setShowPassword] = useState(false);\n    89\t  const [isSubmitting, setIsSubmitting] = useState(false);\n    90\t  const [error, setError] = useState<string | null>(null);\n    91\t  const [success, setSuccess] = useState<string | null>(null);\n    92\t  const [hydrated, setHydrated] = useState(false);\n    93\t\n    94\t  useEffect(() => {\n    95\t    setHydrated(true);\n    96\t  }, []);\n    97\t\n    98\t  function handleModeChange(nextMode: AuthFormMode) {\n    99\t    setMode(nextMode);\n   100\t    setError(null);\n   101\t    setSuccess(null);\n   102\t    setShowPassword(false);\n   103\t  }\n   104\t\n   105\t  async function handleSubmit(event: React.FormEvent<HTMLFormElement>) {\n   106\t    event.preventDefault();\n   107\t    setError(null);\n   108\t    setSuccess(null);\n   109\t\n   110\t    const trimmedEmail = email.trim();\n   111\t    const trimmedFullName = fullName.trim();\n   112\t\n   113\t    if (!trimmedEmail) {\n   114\t      setError(\"Введите email, чтобы продолжить.\");\n   115\t      return;\n   116\t    }\n   117\t    if (!password) {\n   118\t      setError(\"Введите пароль, чтобы продолжить.\");\n   119\t      return;\n   120\t    }\n   121\t    if (mode === \"sign-up\" && !trimmedFullName) {\n   122\t      setError(\"Укажите имя, которое нужно сохранить в профиле.\");\n   123\t      return;\n   124\t    }\n   125\t\n   126\t    setIsSubmitting(true);\n   127\t\n   128\t    try {\n   129\t      if (mode === \"sign-in\") {\n   130\t        const supabase = createSupabaseBrowserClient();\n   131\t        const { data: signInData, error: signInError } =\n   132\t          await supabase.auth.signInWithPassword({\n   133\t            email: trimmedEmail,\n   134\t            password,\n   135\t          });\n   136\t\n   137\t        if (signInError) {\n   138\t          setError(getFriendlyAuthError(signInError.message));\n   139\t          return;\n   140\t        }\n   141\t\n   142\t        const signedInUser = signInData.user;\n   143\t        if (!signedInUser) {\n   144\t          setError(\"Не удалось получить данные сессии. Попробуйте ещё раз.\");\n   145\t          return;\n   146\t        }\n   147\t\n   148\t        // Ensure the browser client has the new session before profiles.role lookup (AP-038).\n   149\t        await supabase.auth.getSession();\n   150\t\n   151\t        let profileRole: string | null | undefined;\n   152\t        const { data: profile, error: profileError } = await supabase\n   153\t          .from(\"profiles\")\n   154\t          .select(\"role\")\n   155\t          .eq(\"id\", signedInUser.id)\n   156\t          .maybeSingle();\n   157\t\n   158\t        if (!profileError) {\n   159\t          profileRole = profile?.role ?? null;\n   160\t        }\n   161\t\n   162\t        const userRole = resolveCanonicalRole({\n   163\t          profileRole,\n   164\t          appMetadataRole: signedInUser.app_metadata?.role as string | undefined,\n   165\t          userMetadataRole: signedInUser.user_metadata?.role as string | undefined,\n   166\t        });\n   167\t\n   168\t        if (profileError && next && isAdminWorkspacePath(next) && userRole !== \"admin\") {\n   169\t          setError(\n   170\t            \"Не удалось проверить права администратора после входа. Попробуйте ещё раз или напишите в поддержку.\",\n   171\t          );\n   172\t          return;\n   173\t        }\n   174\t\n   175\t        if (!userRole) {\n   176\t          setError(\n   177\t            profileError\n   178\t              ? \"Не удалось загрузить профиль после входа. Попробуйте ещё раз или напишите в поддержку.\"\n   179\t              : \"Не удалось определить роль аккаунта. Выйдите и войдите снова или напишите в поддержку.\",\n   180\t          );\n   181\t          return;\n   182\t        }\n   183\t\n   184\t        if (next && isAdminWorkspacePath(next) && userRole !== \"admin\") {\n   185\t          setError(\n   186\t            \"У этого аккаунта нет прав администратора. Войдите под админским email или обратитесь к владельцу доступа.\",\n   187\t          );\n   188\t          return;\n   189\t        }\n   190\t\n   191\t        const destination = resolvePostAuthRedirectPath(userRole, next);\n   192\t\n   193\t        if (!destination) {\n   194\t          setError(\n   195\t            \"Не удалось определить кабинет для входа. Напишите в поддержку.\",\n   196\t          );\n   197\t          return;\n   198\t        }\n   199\t\n   200\t        window.location.assign(destination);\n   201\t        return;\n   202\t      }\n   203\t\n   204\t      // Sign-up: server action creates user + profile + sets app_metadata atomically.\n   205\t      const result = await signUpAction({\n   206\t        email: trimmedEmail,\n   207\t        password,\n   208\t        role,\n   209\t        fullName: trimmedFullName,\n   210\t        phone: phone.trim() || undefined,\n   211\t      });\n   212\t\n   213\t      if (!result.ok) {\n   214\t        setError(getFriendlyAuthError(result.error));\n   215\t        return;\n   216\t      }\n   217\t\n   218\t      window.location.assign(\n   219\t        resolvePostAuthRedirectPath(role, next) ?? result.dashboardPath,\n   220\t      );\n   221\t    } catch {\n   222\t      setError(\"Не удалось выполнить авторизацию. Попробуйте еще раз.\");\n   223\t    } finally {\n   224\t      setIsSubmitting(false);\n   225\t    }\n   226\t  }\n   227\t\n   228\t  const isSignUp = mode === \"sign-up\";\n   229\t  const ctaLabel = isSignUp ? \"Создать профиль\" : \"Войти\";\n   230\t  const toggleLabel = isSignUp\n   231\t    ? \"Уже есть аккаунт? Войти\"\n   232\t    : \"Нет аккаунта? Создать профиль\";\n   233\t\n   234\t  return (\n   235\t    <div className=\"w-[min(100%,30rem)] rounded-glass border border-glass-border bg-glass p-[clamp(1.75rem,4vw,2.5rem)] shadow-glass backdrop-blur-[20px]\">\n   236\t      <div>\n   237\t        <div className=\"flex items-start justify-between gap-4\">\n   238\t          <div className=\"space-y-3\">\n   239\t            <Link\n   240\t              href=\"/\"\n   241\t              className=\"inline-flex w-fit