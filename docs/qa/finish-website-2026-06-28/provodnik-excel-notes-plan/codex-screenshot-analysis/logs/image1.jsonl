{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/features/auth/actions/signUpAction.ts | sed -n '1,260p'\"","aggregated_output":"     1\t\"use server\";\n     2\t\n     3\timport { createSupabaseAdminClient } from \"@/lib/supabase/admin\";\n     4\timport { createSupabaseServerClient } from \"@/lib/supabase/server\";\n     5\timport { getDashboardPathForRole } from \"@/lib/auth/role-routing\";\n     6\t\n     7\ttype SignUpInput = {\n     8\t  email: string;\n     9\t  password: string;\n    10\t  role: string;\n    11\t  fullName: string;\n    12\t  phone?: string;\n    13\t};\n    14\t\n    15\ttype SignUpResult =\n    16\t  | { ok: true; dashboardPath: string }\n    17\t  | { ok: false; error: string };\n    18\t\n    19\tasync function rollbackRecentlyCreatedAuthUser(\n    20\t  admin: ReturnType<typeof createSupabaseAdminClient>,\n    21\t  userId: string,\n    22\t) {\n    23\t  const { data: checkUser, error: lookupError } = await admin.auth.admin.getUserById(userId);\n    24\t  if (lookupError) {\n    25\t    console.error(\"[signUpAction] auth rollback lookup failed:\", lookupError);\n    26\t    return;\n    27\t  }\n    28\t\n    29\t  if (!checkUser?.user) return;\n    30\t\n    31\t  const createdAt = new Date(checkUser.user.created_at).getTime();\n    32\t  const now = Date.now();\n    33\t  if (now - createdAt >= 30_000) return;\n    34\t\n    35\t  const { error: deleteError } = await admin.auth.admin.deleteUser(userId);\n    36\t  if (deleteError) {\n    37\t    console.error(\"[signUpAction] auth rollback delete failed:\", deleteError);\n    38\t  }\n    39\t}\n    40\t\n    41\texport async function signUpAction(input: SignUpInput): Promise<SignUpResult> {\n    42\t  // Public signup allowlist: traveler and guide only. Admin and arbitrary roles\n    43\t  // are rejected before any Supabase call — must be the first executable statement.\n    44\t  if (input.role !== \"traveler\" && input.role !== \"guide\") {\n    45\t    return { ok: false, error: \"forbidden_role\" };\n    46\t  }\n    47\t\n    48\t  const { email, password, fullName, phone } = input;\n    49\t  const safeRole = input.role;\n    50\t\n    51\t  const admin = createSupabaseAdminClient();\n    52\t\n    53\t  const { data: created, error: createError } = await admin.auth.admin.createUser({\n    54\t    email,\n    55\t    password,\n    56\t    email_confirm: true,\n    57\t    user_metadata: { role: safeRole, full_name: fullName },\n    58\t  });\n    59\t\n    60\t  if (createError) {\n    61\t    if (createError.message.toLowerCase().includes(\"already registered\") ||\n    62\t        createError.message.toLowerCase().includes(\"already been registered\") ||\n    63\t        createError.message.toLowerCase().includes(\"duplicate\")) {\n    64\t      return { ok: false, error: \"already_registered\" };\n    65\t    }\n    66\t    return { ok: false, error: \"internal\" };\n    67\t  }\n    68\t\n    69\t  const userId = created.user?.id;\n    70\t  if (!userId) {\n    71\t    return { ok: false, error: \"internal\" };\n    72\t  }\n    73\t\n    74\t  // The profiles upsert and the app_metadata update were previously unchecked:\n    75\t  // a failure left an auth user with no usable profile or role claim behind a\n    76\t  // single generic error. Both are now checked and roll the auth user back, so\n    77\t  // no orphaned account remains and the caller learns the real cause.\n    78\t  const { error: profileError } = await admin.from(\"profiles\").upsert({\n    79\t    id: userId,\n    80\t    role: safeRole,\n    81\t    email,\n    82\t    full_name: fullName,\n    83\t    ...(phone ? { phone } : {}),\n    84\t  });\n    85\t\n    86\t  if (profileError) {\n    87\t    await rollbackRecentlyCreatedAuthUser(admin, userId);\n    88\t    return { ok: false, error: \"profile_failed\" };\n    89\t  }\n    90\t\n    91\t  const { error: roleError } = await admin.auth.admin.updateUserById(userId, {\n    92\t    app_metadata: { role: safeRole },\n    93\t  });\n    94\t\n    95\t  if (roleError) {\n    96\t    await rollbackRecentlyCreatedAuthUser(admin, userId);\n    97\t    return { ok: false, error: \"role_failed\" };\n    98\t  }\n    99\t\n   100\t  const supabase = await createSupabaseServerClient();\n   101\t  const { error: signInError } = await supabase.auth.signInWithPassword({\n   102\t    email,\n   103\t    password,\n   104\t  });\n   105\t\n   106\t  if (signInError) {\n   107\t    // The account is fully provisioned — only the immediate session failed.\n   108\t    // No orphan: the user can sign in directly with the same credentials.\n   109\t    return { ok: false, error: \"signin_after_signup_failed\" };\n   110\t  }\n   111\t\n   112\t  const dashboardPath = getDashboardPathForRole(safeRole) ?? \"/\";\n   113\t  return { ok: true, dashboardPath };\n   114\t}\n","exit_code":0,"status":"completed"}}
